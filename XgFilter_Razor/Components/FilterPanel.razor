@using XgFilter_Lib.Filtering
@using XgFilter_Lib.Enums
@using XgFilter_Lib.Patterns
@using BgDataTypes_Lib
@inject IJSRuntime JS

@* ── FilterPanel.razor ───────────────────────────────────────────────────────
   Owns all filter state. Raises OnFilterConfigChanged only when "Apply Filter"
   is clicked (or Reset). Raises OnFilterDirty whenever any control changes, so
   the parent can disable Run until Apply. Consumers that need a
   DecisionFilterSet call FilterConfig.Build() on the received config.
   State persists to localStorage as a single serialized FilterConfig blob
   (one key) via the lib's FilterConfig.ToJson / TryFromJson.
   Location: XgFilter_Razor/Components/FilterPanel.razor
──────────────────────────────────────────────────────────────────────────── *@

<div class="card mb-4" style="max-width:800px">
    <div class="card-header">
        <strong>Filters</strong>
    </div>
    <div class="card-body">

        @* ── Player ──────────────────────────────────────────────────────────── *@
        <div class="mb-3">
            <label class="form-label">
                Player names
                <small class="text-muted">(comma-separated; blank = all players)</small>
            </label>
            <input class="form-control"
                   placeholder="e.g. Hal, Magriel"
                   value="@_playerText"
                   @oninput="e => { _playerText = e.Value?.ToString() ?? string.Empty; MarkDirty(); }" />
        </div>

        @* ── Decision type ────────────────────────────────────────────────────── *@
        <div class="mb-3">
            <label class="form-label">Decision type</label>
            <div>
                @foreach (var opt in Enum.GetValues<DecisionTypeOption>())
                {
                    <div class="form-check form-check-inline">
                        <input class="form-check-input" type="radio"
                               name="decisionType"
                               id="dt_@opt"
                               checked="@(_decisionType == opt)"
                               @onchange="() => { _decisionType = opt; MarkDirty(); }" />
                        <label class="form-check-label" for="dt_@opt">
                            @opt.ToLabel()
                        </label>
                    </div>
                }
            </div>
        </div>

        @* ── Match score ──────────────────────────────────────────────────────── *@
        <div class="mb-3">
            <label class="form-label">
                Match scores
                <small class="text-muted">(comma-separated; blank = all scores)</small>
            </label>
            <input class="form-control"
                   placeholder="e.g. 4a5a, 1a1a, 1a2aC, money"
                   value="@_matchScoreText"
                   @oninput="e => { _matchScoreText = e.Value?.ToString() ?? string.Empty; MarkDirty(); }" />
            <div class="form-text">
                MaNa is on-roll-anchored — M = points the player on roll needs, N = the
                opponent — so 4a5a and 5a4a are distinct (list both to catch either
                orientation). C suffix = Crawford game; money = money sessions; DMP = 1a1a.
            </div>
        </div>

        @* ── Error range ──────────────────────────────────────────────────────── *@
        <div class="mb-3">
            <label class="form-label">
                Error range
                <small class="text-muted">(inclusive; blank = no bound)</small>
            </label>
            <div class="d-flex gap-2 align-items-center">
                <input class="form-control" style="max-width:140px"
                       type="number" step="0.001" placeholder="Min"
                       value="@_errorMinText"
                       @oninput="e => { _errorMinText = e.Value?.ToString() ?? string.Empty; MarkDirty(); }" />
                <span>–</span>
                <input class="form-control" style="max-width:140px"
                       type="number" step="0.001" placeholder="Max"
                       value="@_errorMaxText"
                       @oninput="e => { _errorMaxText = e.Value?.ToString() ?? string.Empty; MarkDirty(); }" />
            </div>
        </div>

        @* ── Move number range ────────────────────────────────────────────────── *@
        <div class="mb-3">
            <label class="form-label">
                Move number range
                <small class="text-muted">(inclusive; blank = no bound; non-standard-start games are excluded)</small>
            </label>
            <div class="d-flex gap-2 align-items-center">
                <input class="form-control" style="max-width:140px"
                       type="number" step="1" min="1" placeholder="Min"
                       value="@_moveNumberMinText"
                       @oninput="e => { _moveNumberMinText = e.Value?.ToString() ?? string.Empty; MarkDirty(); }" />
                <span>–</span>
                <input class="form-control" style="max-width:140px"
                       type="number" step="1" min="1" placeholder="Max"
                       value="@_moveNumberMaxText"
                       @oninput="e => { _moveNumberMaxText = e.Value?.ToString() ?? string.Empty; MarkDirty(); }" />
            </div>
        </div>

        @* ── Contact type ─────────────────────────────────────────────────────── *@
        <div class="mb-3">
            <label class="form-label">
                Contact type
                <small class="text-muted">(none checked = all types)</small>
            </label>
            <div>
                @foreach (var ct in Enum.GetValues<ContactType>())
                {
                    <div class="form-check form-check-inline">
                        <input class="form-check-input" type="checkbox"
                               id="ct_@ct"
                               checked="@_contactTypes.Contains(ct)"
                               @onchange="(e) => { if (e.Value is bool b && b) _contactTypes.Add(ct); else _contactTypes.Remove(ct); MarkDirty(); }" />
                        <label class="form-check-label" for="ct_@ct">@ct.ToLabel()</label>
                    </div>
                }
            </div>
        </div>

        @* ── Analysis depth ────────────────────────────────────────────────────── *@
        @* Include-list over BgDataTypes_Lib.AnalysisDepthClass (OR semantics;
           none checked = no depth filter). Same facet idiom as Contact type —
           the only differences are the wider member set and that Unknown is a
           first-class, selectable member: checking it is the deliberate opt-in
           to admit unclassified/legacy rows (AnalysisDepthFilter drops them
           otherwise). Rendered in Enum.GetValues declaration order, which is the
           lib's ascending-rigor order, so no UI-side sort rule is imposed. The
           inline form-check wraps the twenty members across rows on its own. *@
        <div class="mb-3">
            <label class="form-label">
                Analysis depth
                <small class="text-muted">(none checked = all depths)</small>
            </label>
            <div>
                @foreach (var ad in Enum.GetValues<AnalysisDepthClass>())
                {
                    <div class="form-check form-check-inline">
                        <input class="form-check-input" type="checkbox"
                               id="ad_@ad"
                               checked="@_analysisDepthClasses.Contains(ad)"
                               @onchange="(e) => { if (e.Value is bool b && b) _analysisDepthClasses.Add(ad); else _analysisDepthClasses.Remove(ad); MarkDirty(); }" />
                        <label class="form-check-label" for="ad_@ad">@ad.ToLabel()</label>
                    </div>
                }
            </div>
        </div>

        @* ── Position pattern ──────────────────────────────────────────────────── *@
        @* Per-point checker-range constraint, entered as the lib's raw bracket
           list until the board-grid widget replaces this field in a later arc.
           Parsed through BoardPattern.TryParse so half-typed input never throws
           out of the panel; while the text is non-blank and unparseable the
           field is marked invalid and Apply is disabled, so an invalid pattern
           can never silently drop the filter the user meant to set. *@
        <div class="mb-3">
            <label class="form-label" for="positionPattern">
                Position pattern
                <small class="text-muted">(per-point checker ranges; blank = no pattern filter)</small>
            </label>
            <input id="positionPattern"
                   class="form-control @(IsPositionPatternValid ? string.Empty : "is-invalid")"
                   placeholder="e.g. [6,2,] [5,,-2] [13,2,]"
                   value="@_positionPatternText"
                   @oninput="e => { _positionPatternText = e.Value?.ToString() ?? string.Empty; MarkDirty(); }" />
            <div class="form-text">
                [pt,min,max] per point; blank bound = unbounded; negative = opponent.
                E.g. [6,2,] [5,,-2] [13,2,].
            </div>
            <div class="invalid-feedback">
                Not a valid bracket list — fix it to apply, or clear it for no pattern filter.
            </div>
        </div>

        @* ── Buttons ──────────────────────────────────────────────────────────── *@
        <div class="d-flex gap-2">
            <button class="btn btn-primary btn-sm"
                    disabled="@(!IsPositionPatternValid)"
                    @onclick="ApplyAsync">
                Apply Filter
            </button>
            <button class="btn btn-outline-secondary btn-sm" @onclick="ResetAsync">
                Reset
            </button>
        </div>

    </div>
</div>

@code {
    /// <summary>
    /// Raised on <b>Apply</b> and on <b>Reset</b> — never per keystroke — carrying
    /// the committed <see cref="FilterConfig"/>. The same instance is first
    /// persisted to <c>localStorage</c> (see <see cref="ConfigKey"/>) so the panel
    /// rehydrates it on the next first render. A consumer that wants a
    /// <c>DecisionFilterSet</c> for in-memory filtering calls <c>cfg.Build()</c> on
    /// the received config; a consumer that ships the selection to a server
    /// serializes <c>cfg</c> as JSON. Required: the panel exists to produce this,
    /// so <see cref="EditorRequiredAttribute"/> makes a missing binding an
    /// <c>RZ2012</c> compile error rather than a silent Razor splat.
    /// </summary>
    [Parameter, EditorRequired] public EventCallback<FilterConfig> OnFilterConfigChanged { get; set; }

    /// <summary>
    /// Raised on every input change (typing, radio, checkbox) so the parent can
    /// disable a Run button until the user commits via Apply — it signals only
    /// that the selection is dirty and carries no payload. Optional by design: a
    /// consumer that doesn't gate downstream actions on dirtiness simply leaves it
    /// unbound, and the panel still emits on Apply. It is deliberately <em>not</em>
    /// <c>[EditorRequired]</c> for that reason.
    /// </summary>
    [Parameter] public EventCallback OnFilterDirty { get; set; }

    // Single localStorage key holding the whole filter state as one serialized
    // FilterConfig blob. The lib owns the JSON shape (ToJson / TryFromJson);
    // this component never touches a JSON serializer directly.
    private const string ConfigKey = "xg_filter_config";

    // Free-text / numeric buffers. These exist only because in-progress typing
    // needs a string distinct from the parsed value; they are transient
    // view-state — hydrated from the config on restore, flushed back into a
    // config on Apply, and never persisted on their own.
    private string _playerText = string.Empty;
    private string _matchScoreText = string.Empty;
    private string _errorMinText = string.Empty;
    private string _errorMaxText = string.Empty;
    private string _moveNumberMinText = string.Empty;
    private string _moveNumberMaxText = string.Empty;
    private string _positionPatternText = string.Empty;

    // Enum state needs no string buffer — the controls bind directly.
    private DecisionTypeOption _decisionType = DecisionTypeOption.Both;
    private HashSet<ContactType> _contactTypes = new();
    private HashSet<AnalysisDepthClass> _analysisDepthClasses = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var stored = await JS.InvokeAsync<string?>("localStorage.getItem", ConfigKey);
        // Tolerant restore: a missing key, the literal null token, or corrupt
        // JSON all yield a fresh default config — no try/catch here.
        FilterConfig.TryFromJson(stored, out var cfg);
        HydrateFrom(cfg);

        StateHasChanged();
    }

    private void MarkDirty() => OnFilterDirty.InvokeAsync();

    private Task ApplyAsync() => PersistAndRaiseAsync(BuildConfig());

    private Task ResetAsync()
    {
        var cfg = new FilterConfig();
        HydrateFrom(cfg);              // clear every edit-field back to defaults
        return PersistAndRaiseAsync(cfg);
    }

    private async Task PersistAndRaiseAsync(FilterConfig cfg)
    {
        await JS.InvokeVoidAsync("localStorage.setItem", ConfigKey, cfg.ToJson());
        await OnFilterConfigChanged.InvokeAsync(cfg);
    }

    // Flush the current buffers / enum state into a single FilterConfig.
    private FilterConfig BuildConfig() => new()
    {
        Players = SplitTokens(_playerText),
        DecisionType = _decisionType,
        MatchScores = SplitTokens(_matchScoreText),
        ErrorMin = ParseDouble(_errorMinText),
        ErrorMax = ParseDouble(_errorMaxText),
        MoveNumberMin = ParseInt(_moveNumberMinText),
        MoveNumberMax = ParseInt(_moveNumberMaxText),
        ContactTypes = _contactTypes.ToList(),
        AnalysisDepthClasses = _analysisDepthClasses.ToList(),
        PositionPattern = ParsePositionPattern(_positionPatternText),
    };

    // Inverse of BuildConfig: project a config onto the buffers / enum state.
    private void HydrateFrom(FilterConfig cfg)
    {
        _playerText = string.Join(", ", cfg.Players);
        _decisionType = cfg.DecisionType;
        _matchScoreText = string.Join(", ", cfg.MatchScores);
        _errorMinText = FormatNumber(cfg.ErrorMin);
        _errorMaxText = FormatNumber(cfg.ErrorMax);
        _moveNumberMinText = FormatNumber(cfg.MoveNumberMin);
        _moveNumberMaxText = FormatNumber(cfg.MoveNumberMax);
        _contactTypes = new HashSet<ContactType>(cfg.ContactTypes);
        _analysisDepthClasses = new HashSet<AnalysisDepthClass>(cfg.AnalysisDepthClasses);
        _positionPatternText = cfg.PositionPattern?.ToBracketList() ?? string.Empty;
    }

    // True when the position-pattern buffer is committable: a blank buffer is
    // "no pattern filter," and any non-blank buffer must parse as a bracket
    // list. Drives both the field's is-invalid styling and the Apply gate, so
    // half-typed input is flagged rather than silently dropped at Apply.
    private bool IsPositionPatternValid =>
        string.IsNullOrWhiteSpace(_positionPatternText)
        || BoardPattern.TryParse(_positionPatternText, out _);

    // Buffer → PositionPattern. A blank buffer is no filter (null); otherwise
    // the parsed pattern. TryParse can only fail here for invalid text, which
    // the Apply gate (IsPositionPatternValid) already prevents from reaching
    // BuildConfig — the null fallback is a defensive belt, not a silent drop.
    private static BoardPattern? ParsePositionPattern(string raw) =>
        string.IsNullOrWhiteSpace(raw)
            ? null
            : BoardPattern.TryParse(raw, out var pattern) ? pattern : null;

    private static List<string> SplitTokens(string raw) =>
        raw.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
           .Where(s => s.Length > 0).ToList();

    private static double? ParseDouble(string raw) =>
        double.TryParse(raw, System.Globalization.NumberStyles.Any,
                        System.Globalization.CultureInfo.InvariantCulture, out var v) ? v : null;

    private static int? ParseInt(string raw) =>
        int.TryParse(raw, System.Globalization.NumberStyles.Integer,
                     System.Globalization.CultureInfo.InvariantCulture, out var v) ? v : null;

    private static string FormatNumber<T>(T? value) where T : struct, IFormattable =>
        value?.ToString(null, System.Globalization.CultureInfo.InvariantCulture) ?? string.Empty;
}
