@using XgFilter_Lib.Filtering
@using XgFilter_Lib.Enums
@using XgFilter_Razor.Shared
@inject IJSRuntime JS

@* ── FilterPanel.razor ───────────────────────────────────────────────────────
   Owns all filter state. Raises OnFiltersChanged and OnFilterConfigChanged
   only when "Apply Filter" is clicked (or Reset). Raises OnFilterDirty
   whenever any control changes, so the parent can disable Run until Apply.
   State persisted to localStorage.
   Location: XgFilter_Razor/Components/FilterPanel.razor
──────────────────────────────────────────────────────────────────────────── *@

<div class="card mb-4" style="max-width:800px">
    <div class="card-header">
        <strong>Filters</strong>
    </div>
    <div class="card-body">

        @* ── Player ──────────────────────────────────────────────────────────── *@
        <div class="mb-3">
            <label class="form-label">
                Player names
                <small class="text-muted">(comma-separated; blank = all players)</small>
            </label>
            <input class="form-control"
                   placeholder="e.g. Hal, Magriel"
                   value="@_playerText"
                   @oninput="e => { _playerText = e.Value?.ToString() ?? string.Empty; MarkDirty(); }" />
        </div>

        @* ── Decision type ────────────────────────────────────────────────────── *@
        <div class="mb-3">
            <label class="form-label">Decision type</label>
            <div>
                @foreach (var opt in Enum.GetValues<DecisionTypeOption>())
                {
                    <div class="form-check form-check-inline">
                        <input class="form-check-input" type="radio"
                               name="decisionType"
                               id="dt_@opt"
                               checked="@(_decisionType == opt)"
                               @onchange="() => { _decisionType = opt; MarkDirty(); }" />
                        <label class="form-check-label" for="dt_@opt">
                            @DecisionTypeLabel(opt)
                        </label>
                    </div>
                }
            </div>
        </div>

        @* ── Match score ──────────────────────────────────────────────────────── *@
        <div class="mb-3">
            <label class="form-label">
                Match scores
                <small class="text-muted">(comma-separated; blank = all scores)</small>
            </label>
            <input class="form-control"
                   placeholder="e.g. 5a5a, DMP, money"
                   value="@_matchScoreText"
                   @oninput="e => { _matchScoreText = e.Value?.ToString() ?? string.Empty; MarkDirty(); }" />
        </div>

        @* ── Error range ──────────────────────────────────────────────────────── *@
        <div class="mb-3">
            <label class="form-label">
                Error range
                <small class="text-muted">(inclusive; blank = no bound)</small>
            </label>
            <div class="d-flex gap-2 align-items-center">
                <input class="form-control" style="max-width:140px"
                       type="number" step="0.001" placeholder="Min"
                       value="@_errorMinText"
                       @oninput="e => { _errorMinText = e.Value?.ToString() ?? string.Empty; MarkDirty(); }" />
                <span>–</span>
                <input class="form-control" style="max-width:140px"
                       type="number" step="0.001" placeholder="Max"
                       value="@_errorMaxText"
                       @oninput="e => { _errorMaxText = e.Value?.ToString() ?? string.Empty; MarkDirty(); }" />
            </div>
        </div>

        @* ── Move number range ────────────────────────────────────────────────── *@
        <div class="mb-3">
            <label class="form-label">
                Move number range
                <small class="text-muted">(inclusive; blank = no bound; non-standard-start games are excluded)</small>
            </label>
            <div class="d-flex gap-2 align-items-center">
                <input class="form-control" style="max-width:140px"
                       type="number" step="1" min="1" placeholder="Min"
                       value="@_moveNumberMinText"
                       @oninput="e => { _moveNumberMinText = e.Value?.ToString() ?? string.Empty; MarkDirty(); }" />
                <span>–</span>
                <input class="form-control" style="max-width:140px"
                       type="number" step="1" min="1" placeholder="Max"
                       value="@_moveNumberMaxText"
                       @oninput="e => { _moveNumberMaxText = e.Value?.ToString() ?? string.Empty; MarkDirty(); }" />
            </div>
        </div>

        @* ── Position type ────────────────────────────────────────────────────── *@
        <div class="mb-3">
            <label class="form-label">
                Position type
                <small class="text-muted">(none checked = all types)</small>
            </label>
            <div>
                @foreach (var pt in Enum.GetValues<PositionType>())
                {
                    <div class="form-check form-check-inline">
                        <input class="form-check-input" type="checkbox"
                               id="pt_@pt"
                               checked="@_positionTypes.Contains(pt)"
                               @onchange="(e) => { if (e.Value is bool b && b) _positionTypes.Add(pt); else _positionTypes.Remove(pt); MarkDirty(); }" />
                        <label class="form-check-label" for="pt_@pt">@pt</label>
                    </div>
                }
            </div>
        </div>

        @* ── Play type ────────────────────────────────────────────────────────── *@
        <div class="mb-3">
            <label class="form-label">
                Play type
                <small class="text-muted">(checker plays only; none checked = all types)</small>
            </label>
            <div>
                @foreach (var pt in Enum.GetValues<PlayType>())
                {
                    <div class="form-check form-check-inline">
                        <input class="form-check-input" type="checkbox"
                               id="plt_@pt"
                               checked="@_playTypes.Contains(pt)"
                               @onchange="(e) => { if (e.Value is bool b && b) _playTypes.Add(pt); else _playTypes.Remove(pt); MarkDirty(); }" />
                        <label class="form-check-label" for="plt_@pt">@pt.ToLabel()</label>
                    </div>
                }
            </div>
        </div>

        @* ── Buttons ──────────────────────────────────────────────────────────── *@
        <div class="d-flex gap-2">
            <button class="btn btn-primary btn-sm" @onclick="ApplyAsync">
                Apply Filter
            </button>
            <button class="btn btn-outline-secondary btn-sm" @onclick="ResetAsync">
                Reset
            </button>
        </div>

    </div>
</div>

@code {
    [Parameter] public EventCallback<DecisionFilterSet> OnFiltersChanged { get; set; }
    [Parameter] public EventCallback<FilterConfig> OnFilterConfigChanged { get; set; }
    [Parameter] public EventCallback OnFilterDirty { get; set; }

    private string _playerText = string.Empty;
    private DecisionTypeOption _decisionType = DecisionTypeOption.Both;
    private string _matchScoreText = string.Empty;
    private string _errorMinText = string.Empty;
    private string _errorMaxText = string.Empty;
    private string _moveNumberMinText = string.Empty;
    private string _moveNumberMaxText = string.Empty;
    private HashSet<PositionType> _positionTypes = new();
    private HashSet<PlayType> _playTypes = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        _playerText = await JS.InvokeAsync<string?>("localStorage.getItem", "xg_filter_player") ?? string.Empty;
        _matchScoreText = await JS.InvokeAsync<string?>("localStorage.getItem", "xg_filter_matchscore") ?? string.Empty;
        _errorMinText = await JS.InvokeAsync<string?>("localStorage.getItem", "xg_filter_errormin") ?? string.Empty;
        _errorMaxText = await JS.InvokeAsync<string?>("localStorage.getItem", "xg_filter_errormax") ?? string.Empty;
        _moveNumberMinText = await JS.InvokeAsync<string?>("localStorage.getItem", "xg_filter_movenumbermin") ?? string.Empty;
        _moveNumberMaxText = await JS.InvokeAsync<string?>("localStorage.getItem", "xg_filter_movenumbermax") ?? string.Empty;

        var dtRaw = await JS.InvokeAsync<string?>("localStorage.getItem", "xg_filter_decisiontype");
        if (Enum.TryParse<DecisionTypeOption>(dtRaw, out var dt))
            _decisionType = dt;

        var ptRaw = await JS.InvokeAsync<string?>("localStorage.getItem", "xg_filter_positiontypes") ?? string.Empty;
        _positionTypes = DeserializeEnumSet<PositionType>(ptRaw);

        var pltRaw = await JS.InvokeAsync<string?>("localStorage.getItem", "xg_filter_playtypes") ?? string.Empty;
        _playTypes = DeserializeEnumSet<PlayType>(pltRaw);

        StateHasChanged();
    }

    private void MarkDirty() => OnFilterDirty.InvokeAsync();

    private async Task ApplyAsync()
    {
        await PersistAsync();
        await RaiseAsync();
    }

    private async Task ResetAsync()
    {
        _playerText = string.Empty;
        _decisionType = DecisionTypeOption.Both;
        _matchScoreText = string.Empty;
        _errorMinText = string.Empty;
        _errorMaxText = string.Empty;
        _moveNumberMinText = string.Empty;
        _moveNumberMaxText = string.Empty;
        _positionTypes = new();
        _playTypes = new();
        await PersistAsync();
        await RaiseAsync();
    }

    private async Task PersistAsync()
    {
        await JS.InvokeVoidAsync("localStorage.setItem", "xg_filter_player", _playerText);
        await JS.InvokeVoidAsync("localStorage.setItem", "xg_filter_matchscore", _matchScoreText);
        await JS.InvokeVoidAsync("localStorage.setItem", "xg_filter_errormin", _errorMinText);
        await JS.InvokeVoidAsync("localStorage.setItem", "xg_filter_errormax", _errorMaxText);
        await JS.InvokeVoidAsync("localStorage.setItem", "xg_filter_movenumbermin", _moveNumberMinText);
        await JS.InvokeVoidAsync("localStorage.setItem", "xg_filter_movenumbermax", _moveNumberMaxText);
        await JS.InvokeVoidAsync("localStorage.setItem", "xg_filter_decisiontype", _decisionType.ToString());
        await JS.InvokeVoidAsync("localStorage.setItem", "xg_filter_positiontypes", SerializeEnumSet(_positionTypes));
        await JS.InvokeVoidAsync("localStorage.setItem", "xg_filter_playtypes", SerializeEnumSet(_playTypes));
    }

    private async Task RaiseAsync()
    {
        // Raise DecisionFilterSet for web mode (in-memory filtering)
        var set = new DecisionFilterSet();
        var players = SplitTokens(_playerText);
        if (players.Count > 0) set.Add(new PlayerFilter(players));
        set.Add(new DecisionTypeFilter(_decisionType));
        var scores = SplitTokens(_matchScoreText);
        if (scores.Count > 0) set.Add(new MatchScoreFilter(scores));
        var min = ParseDouble(_errorMinText);
        var max = ParseDouble(_errorMaxText);
        if (min.HasValue || max.HasValue) set.Add(new ErrorRangeFilter(min, max));
        var moveMin = ParseInt(_moveNumberMinText);
        var moveMax = ParseInt(_moveNumberMaxText);
        if (moveMin.HasValue || moveMax.HasValue) set.Add(new MoveNumberFilter(moveMin, moveMax));
        if (_positionTypes.Count > 0) set.Add(new PositionTypeFilter(_positionTypes));
        if (_playTypes.Count > 0) set.Add(new PlayTypeFilter(_playTypes));
        await OnFiltersChanged.InvokeAsync(set);

        // Raise FilterConfig for local mode (HTTP POST)
        var cfg = new FilterConfig
        {
            Players = SplitTokens(_playerText),
            DecisionType = _decisionType.ToString(),
            MatchScores = SplitTokens(_matchScoreText),
            ErrorMin = ParseDouble(_errorMinText),
            ErrorMax = ParseDouble(_errorMaxText),
            MoveNumberMin = ParseInt(_moveNumberMinText),
            MoveNumberMax = ParseInt(_moveNumberMaxText),
            PositionTypes = _positionTypes.Select(p => p.ToString()).ToList(),
            PlayTypes = _playTypes.Select(p => p.ToString()).ToList(),
        };
        await OnFilterConfigChanged.InvokeAsync(cfg);
    }

    private static List<string> SplitTokens(string raw) =>
        raw.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
           .Where(s => s.Length > 0).ToList();

    private static double? ParseDouble(string raw) =>
        double.TryParse(raw, System.Globalization.NumberStyles.Any,
                        System.Globalization.CultureInfo.InvariantCulture, out var v) ? v : null;

    private static int? ParseInt(string raw) =>
        int.TryParse(raw, System.Globalization.NumberStyles.Integer,
                     System.Globalization.CultureInfo.InvariantCulture, out var v) ? v : null;

    private static string SerializeEnumSet<T>(HashSet<T> set) where T : struct, Enum =>
        string.Join(",", set.Select(v => v.ToString()));

    private static HashSet<T> DeserializeEnumSet<T>(string raw) where T : struct, Enum
    {
        var result = new HashSet<T>();
        foreach (var token in raw.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
            if (Enum.TryParse<T>(token, out var v)) result.Add(v);
        return result;
    }

    private static string DecisionTypeLabel(DecisionTypeOption opt) => opt switch
    {
        DecisionTypeOption.Both => "Both",
        DecisionTypeOption.CheckerPlaysOnly => "Checker plays only",
        DecisionTypeOption.CubeOnly => "Cube only",
        _ => opt.ToString(),
    };
}
