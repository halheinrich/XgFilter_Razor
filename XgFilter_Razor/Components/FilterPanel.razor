@using System.Diagnostics.CodeAnalysis
@using XgFilter_Lib.Filtering
@using XgFilter_Lib.Enums
@using XgFilter_Lib.Patterns
@using BgDataTypes_Lib
@inject IJSRuntime JS

@* ── FilterPanel.razor ───────────────────────────────────────────────────────
   Owns all filter state. Raises OnFilterConfigChanged only when "Apply Filter"
   is clicked (or Reset). Raises OnFilterDirty whenever any control changes, so
   the parent can disable Run until Apply. Consumers that need a
   DecisionFilterSet call FilterConfig.Build() on the received config.
   State persists to localStorage as a single serialized FilterConfig blob
   (one key) via the lib's FilterConfig.ToJson / TryFromJson.
   Location: XgFilter_Razor/Components/FilterPanel.razor
──────────────────────────────────────────────────────────────────────────── *@

<div class="card mb-4" style="max-width:800px">
    <div class="card-header">
        <strong>Filters</strong>
    </div>
    <div class="card-body">

        @* ── Player ──────────────────────────────────────────────────────────── *@
        <div class="mb-3">
            <label class="form-label">
                Player names
                <small class="text-muted">(comma-separated; blank = all players)</small>
            </label>
            <input class="form-control"
                   placeholder="e.g. Hal, Magriel"
                   value="@_playerText"
                   @oninput="e => { _playerText = e.Value?.ToString() ?? string.Empty; MarkDirty(); }" />
        </div>

        @* ── Decision type ────────────────────────────────────────────────────── *@
        <div class="mb-3">
            <label class="form-label">Decision type</label>
            <div>
                @foreach (var opt in Enum.GetValues<DecisionTypeOption>())
                {
                    <div class="form-check form-check-inline">
                        <input class="form-check-input" type="radio"
                               name="decisionType"
                               id="dt_@opt"
                               checked="@(_decisionType == opt)"
                               @onchange="() => { _decisionType = opt; MarkDirty(); }" />
                        <label class="form-check-label" for="dt_@opt">
                            @opt.ToLabel()
                        </label>
                    </div>
                }
            </div>
        </div>

        @* ── Match score ──────────────────────────────────────────────────────── *@
        <div class="mb-3">
            <label class="form-label">
                Match scores
                <small class="text-muted">(comma-separated; blank = all scores)</small>
            </label>
            <input class="form-control"
                   placeholder="e.g. 4a5a, 1a1a, 1a2aC, money"
                   value="@_matchScoreText"
                   @oninput="e => { _matchScoreText = e.Value?.ToString() ?? string.Empty; MarkDirty(); }" />
            <div class="form-text">
                MaNa is on-roll-anchored — M = points the player on roll needs, N = the
                opponent — so 4a5a and 5a4a are distinct (list both to catch either
                orientation). C suffix = Crawford game; money = money sessions; DMP = 1a1a.
            </div>
        </div>

        @* ── Error range ──────────────────────────────────────────────────────── *@
        <div class="mb-3">
            <label class="form-label">
                Error range
                <small class="text-muted">(inclusive; blank = no bound)</small>
            </label>
            <div class="d-flex gap-2 align-items-center">
                <input class="form-control" style="max-width:140px"
                       type="number" step="0.001" placeholder="Min"
                       value="@_errorMinText"
                       @oninput="e => { _errorMinText = e.Value?.ToString() ?? string.Empty; MarkDirty(); }" />
                <span>–</span>
                <input class="form-control" style="max-width:140px"
                       type="number" step="0.001" placeholder="Max"
                       value="@_errorMaxText"
                       @oninput="e => { _errorMaxText = e.Value?.ToString() ?? string.Empty; MarkDirty(); }" />
            </div>
        </div>

        @* ── Move number range ────────────────────────────────────────────────── *@
        <div class="mb-3">
            <label class="form-label">
                Move number range
                <small class="text-muted">(inclusive; blank = no bound; non-standard-start games are excluded)</small>
            </label>
            <div class="d-flex gap-2 align-items-center">
                <input class="form-control" style="max-width:140px"
                       type="number" step="1" min="1" placeholder="Min"
                       value="@_moveNumberMinText"
                       @oninput="e => { _moveNumberMinText = e.Value?.ToString() ?? string.Empty; MarkDirty(); }" />
                <span>–</span>
                <input class="form-control" style="max-width:140px"
                       type="number" step="1" min="1" placeholder="Max"
                       value="@_moveNumberMaxText"
                       @oninput="e => { _moveNumberMaxText = e.Value?.ToString() ?? string.Empty; MarkDirty(); }" />
            </div>
        </div>

        @* ── Contact type ─────────────────────────────────────────────────────── *@
        <div class="mb-3">
            <label class="form-label">
                Contact type
                <small class="text-muted">(none checked = all types)</small>
            </label>
            <div>
                @foreach (var ct in Enum.GetValues<ContactType>())
                {
                    <div class="form-check form-check-inline">
                        <input class="form-check-input" type="checkbox"
                               id="ct_@ct"
                               checked="@_contactTypes.Contains(ct)"
                               @onchange="(e) => { if (e.Value is bool b && b) _contactTypes.Add(ct); else _contactTypes.Remove(ct); MarkDirty(); }" />
                        <label class="form-check-label" for="ct_@ct">@ct.ToLabel()</label>
                    </div>
                }
            </div>
        </div>

        @* ── Analysis depth ────────────────────────────────────────────────────── *@
        @* Two-axis facet over BgDataTypes_Lib's AnalysisMode × AnalysisLevel.
           The panel binds three raw-intent inputs — a checked-level set plus the
           two mode toggles — and never derives modes itself: FilterConfig.Build()
           is the single owner of the mode-set semantics (Rollouts → Rollout,
           Book rollouts → BookRollout, neither toggle → Evaluation, nothing
           selected at all → facet off). Re-encoding that here would duplicate the
           SSOT and silently drift — see this panel's Pitfalls and XgFilter_Lib's
           Depth-facet block. Levels render in Enum.GetValues declaration order
           (the lib's ascending-rigor order), so no UI-side sort rule is imposed;
           Unknown is a first-class, selectable level (checking it opts legacy /
           unenriched rows back in on whichever mode is selected). The two mode
           toggles are a distinct axis, not more members of the level list, so
           they sit in a rule-separated group below the checkboxes. Their labels
           come from AnalysisMode's [Description]s via EnumLabel.ToLabel — display
           text stays owned by the enum, never hardcoded here. *@
        <div class="mb-3">
            <label class="form-label">
                Analysis depth
                <small class="text-muted">(toggles off = plain evaluations; levels filter the selected mode; nothing selected = facet off)</small>
            </label>
            <div>
                @foreach (var level in Enum.GetValues<AnalysisLevel>())
                {
                    <div class="form-check form-check-inline">
                        <input class="form-check-input" type="checkbox"
                               id="al_@level"
                               checked="@_analysisLevels.Contains(level)"
                               @onchange="(e) => { if (e.Value is bool b && b) _analysisLevels.Add(level); else _analysisLevels.Remove(level); MarkDirty(); }" />
                        <label class="form-check-label" for="al_@level">@level.ToLabel()</label>
                    </div>
                }
            </div>
            <div class="mt-2 pt-2 border-top">
                <div class="form-check form-check-inline">
                    <input class="form-check-input" type="checkbox"
                           id="am_Rollout"
                           checked="@_includeRollouts"
                           @onchange="(e) => { _includeRollouts = e.Value is bool b && b; MarkDirty(); }" />
                    <label class="form-check-label" for="am_Rollout">@AnalysisMode.Rollout.ToLabel()</label>
                </div>
                <div class="form-check form-check-inline">
                    <input class="form-check-input" type="checkbox"
                           id="am_BookRollout"
                           checked="@_includeBookRollouts"
                           @onchange="(e) => { _includeBookRollouts = e.Value is bool b && b; MarkDirty(); }" />
                    <label class="form-check-label" for="am_BookRollout">@AnalysisMode.BookRollout.ToLabel()</label>
                </div>
            </div>
        </div>

        @* ── Dice rolls ────────────────────────────────────────────────────────── *@
        @* One checkbox per distinct roll, enumerated from DiceRoll.All — the lib
           owns both the 21-roll set and its ascending canonical order (11, 21, 22,
           31, … 66, the six doubles included), so the panel imposes no local roll
           list or sort rule. Labels are the roll's own canonical token
           (DiceRoll.ToString → "31"), rendered verbatim: display text stays owned
           by the type, exactly as the enum facets defer to ToLabel. (A hyphenated
           "3-1" presentation was considered; "31" keeps the panel free of any
           label-munging and matches the lib's token one-for-one.) Selections are
           stored raw in _diceRolls and handed to FilterConfig.Build() verbatim —
           the panel derives nothing. None checked = facet off (Build() skips the
           filter); the roll set is canonical/unordered, so checking "31" admits
           both dice orders, and cube rows (no roll) never pass an active filter. *@
        <div class="mb-3">
            <label class="form-label">
                Dice rolls
                <small class="text-muted">(none checked = all rolls; cube decisions never match)</small>
            </label>
            <div>
                @foreach (var roll in DiceRoll.All)
                {
                    <div class="form-check form-check-inline">
                        <input class="form-check-input" type="checkbox"
                               id="dr_@roll"
                               checked="@_diceRolls.Contains(roll)"
                               @onchange="(e) => { if (e.Value is bool b && b) _diceRolls.Add(roll); else _diceRolls.Remove(roll); MarkDirty(); }" />
                        <label class="form-check-label" for="dr_@roll">@roll</label>
                    </div>
                }
            </div>
        </div>

        @* ── Position pattern ──────────────────────────────────────────────────── *@
        @* Per-location checker-range constraint, entered as the lib's raw bracket
           list until the board-grid widget replaces this field in a later arc.
           Parsed through BoardPattern.TryParse so half-typed input never throws
           out of the panel; while the text is non-blank and unparseable the
           field is marked invalid and Apply is disabled, so an invalid pattern
           can never silently drop the filter the user meant to set.

           The help text below documents the lib's location vocabulary — board
           indices plus the named borne-off tokens — but does not re-implement it:
           BoardPattern remains the single source of truth for what parses, and a
           wrong-signed borne-off bound (say [off,,-2]) fails TryParse and lands
           in the same invalid-field state as any other unparseable text. *@
        <div class="mb-3">
            <label class="form-label" for="positionPattern">
                Position pattern
                <small class="text-muted">(checker ranges by location; blank = no pattern filter)</small>
            </label>
            <input id="positionPattern"
                   class="form-control @(IsPositionPatternValid ? string.Empty : "is-invalid")"
                   placeholder="e.g. [6,2,] [5,,-2] [opp-off,,-2]"
                   value="@_positionPatternText"
                   @oninput="e => { _positionPatternText = e.Value?.ToString() ?? string.Empty; MarkDirty(); }" />
            <div class="form-text">
                [location,min,max] per location; blank bound = unbounded; positive counts
                belong to the player on roll, negative to the opponent.
                Locations: points 1–24, bar 25 (player on roll) and bar 0 (opponent),
                plus borne off — off for the player on roll (bounds 0 to 15) and
                opp-off for the opponent (bounds -15 to 0).
                E.g. [6,2,] [5,,-2] [25,1,] [opp-off,,-2] [off,10,].
            </div>
            <div class="invalid-feedback">
                Not a valid bracket list — fix it to apply, or clear it for no pattern filter.
            </div>
        </div>

        @* ── Buttons ──────────────────────────────────────────────────────────── *@
        <div class="d-flex gap-2">
            <button class="btn btn-primary btn-sm"
                    disabled="@(!IsPositionPatternValid)"
                    @onclick="ApplyAsync">
                Apply Filter
            </button>
            <button class="btn btn-outline-secondary btn-sm" @onclick="ResetAsync">
                Reset
            </button>
        </div>

    </div>
</div>

@code {
    /// <summary>
    /// Raised on <b>Apply</b> and on <b>Reset</b> — never per keystroke — carrying
    /// the committed <see cref="FilterConfig"/>. The same instance is first
    /// persisted to <c>localStorage</c> (see <see cref="ConfigKey"/>) so the panel
    /// rehydrates it on the next first render. A consumer that wants a
    /// <c>DecisionFilterSet</c> for in-memory filtering calls <c>cfg.Build()</c> on
    /// the received config; a consumer that ships the selection to a server
    /// serializes <c>cfg</c> as JSON. Required: the panel exists to produce this,
    /// so <see cref="EditorRequiredAttribute"/> makes a missing binding an
    /// <c>RZ2012</c> compile error rather than a silent Razor splat.
    /// </summary>
    [Parameter, EditorRequired] public EventCallback<FilterConfig> OnFilterConfigChanged { get; set; }

    /// <summary>
    /// Raised on every input change (typing, radio, checkbox) so the parent can
    /// disable a Run button until the user commits via Apply — it signals only
    /// that the selection is dirty and carries no payload. Optional by design: a
    /// consumer that doesn't gate downstream actions on dirtiness simply leaves it
    /// unbound, and the panel still emits on Apply. It is deliberately <em>not</em>
    /// <c>[EditorRequired]</c> for that reason.
    /// </summary>
    [Parameter] public EventCallback OnFilterDirty { get; set; }

    // Single localStorage key holding the whole filter state as one serialized
    // FilterConfig blob. The lib owns the JSON shape (ToJson / TryFromJson);
    // this component never touches a JSON serializer directly.
    private const string ConfigKey = "xg_filter_config";

    // Free-text / numeric buffers. These exist only because in-progress typing
    // needs a string distinct from the parsed value; they are transient
    // view-state — hydrated from the config on restore, flushed back into a
    // config on Apply, and never persisted on their own.
    private string _playerText = string.Empty;
    private string _matchScoreText = string.Empty;
    private string _errorMinText = string.Empty;
    private string _errorMaxText = string.Empty;
    private string _moveNumberMinText = string.Empty;
    private string _moveNumberMaxText = string.Empty;
    private string _positionPatternText = string.Empty;

    // Enum state needs no string buffer — the controls bind directly.
    private DecisionTypeOption _decisionType = DecisionTypeOption.Both;
    private HashSet<ContactType> _contactTypes = new();

    // Depth facet — raw user intent along two axes, stored verbatim and handed
    // to FilterConfig.Build() which owns the mode-set derivation. The panel
    // never maps these to an AnalysisMode set itself (that SSOT lives in the
    // lib; see the Analysis-depth markup comment).
    private HashSet<AnalysisLevel> _analysisLevels = new();
    private bool _includeRollouts;
    private bool _includeBookRollouts;

    // Dice facet — the raw set of admitted rolls, stored verbatim and handed to
    // FilterConfig.Build(); empty = facet off. The roll set and its order are the
    // lib's (DiceRoll.All), never re-derived here.
    private HashSet<DiceRoll> _diceRolls = new();

    // True once LoadConfig has staged an externally supplied config. The
    // first-render localStorage restore checks it both before and after its
    // await, so a restore completing late can never clobber an external load.
    // Blazor's single-threaded sync context makes the segments between awaits
    // atomic — a plain bool is a sufficient guard, no locking.
    private bool _externalConfigLoaded;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        if (_externalConfigLoaded) return;

        var stored = await JS.InvokeAsync<string?>("localStorage.getItem", ConfigKey);

        // Re-check after the await: a host's LoadConfig may have run while the
        // interop was in flight, and the external config must win.
        if (_externalConfigLoaded) return;

        // Tolerant restore: a missing key, the literal null token, or corrupt
        // JSON all yield a fresh default config — no try/catch here.
        FilterConfig.TryFromJson(stored, out var cfg);
        HydrateFrom(cfg);

        StateHasChanged();
    }

    /// <summary>
    /// Projects <paramref name="config"/> into the panel's edit buffers as a
    /// staging-only bulk edit — exactly as if the user had typed every value.
    /// No <em>Apply-side</em> effects occur: nothing is persisted to
    /// <c>localStorage</c> and <see cref="OnFilterConfigChanged"/> is not
    /// raised — the user (or host) still commits via Apply.
    /// <see cref="OnFilterDirty"/> <em>is</em> raised, unconditionally, like
    /// any other edit gesture: after a load the staged state diverges from the
    /// last-applied config, and a host gating actions on dirtiness must hear
    /// about it. Calling this also suppresses the first-render
    /// <c>localStorage</c> restore, so a config loaded during host startup
    /// cannot be clobbered when the restore's interop completes afterwards.
    /// Must be called on the renderer's synchronization context (any event
    /// handler or lifecycle method qualifies), typically via <c>&#64;ref</c>.
    /// </summary>
    /// <param name="config">The configuration to stage. Read, never stored.</param>
    /// <exception cref="ArgumentNullException">
    /// Thrown when <paramref name="config"/> is <see langword="null"/>.
    /// </exception>
    public void LoadConfig(FilterConfig config)
    {
        ArgumentNullException.ThrowIfNull(config);
        _externalConfigLoaded = true;
        HydrateFrom(config);
        MarkDirty();
        StateHasChanged();
    }

    /// <summary>
    /// Snapshots the current edit buffers — including unapplied edits — into a
    /// <see cref="FilterConfig"/>, for host-driven save-as while the panel is
    /// dirty. The gate is exactly Apply's, single-sourced through the same
    /// build path: this fails only when the position-pattern text is non-blank
    /// and unparseable, the one state in which Apply is disabled. It is
    /// deliberately no stricter than Apply — match-score tokens ride raw here
    /// as on the Apply path, validated downstream by
    /// <see cref="FilterConfig.Build"/> — so save-as can capture exactly what
    /// Apply could produce.
    /// </summary>
    /// <param name="config">
    /// The snapshot when this returns <see langword="true"/>; otherwise
    /// <see langword="null"/>.
    /// </param>
    /// <returns>
    /// <see langword="true"/> when the buffers are in a state Apply would
    /// accept; <see langword="false"/> otherwise.
    /// </returns>
    public bool TryGetEditedConfig([NotNullWhen(true)] out FilterConfig? config)
    {
        if (!IsPositionPatternValid)
        {
            config = null;
            return false;
        }

        config = BuildConfig();
        return true;
    }

    private void MarkDirty() => OnFilterDirty.InvokeAsync();

    private Task ApplyAsync() => PersistAndRaiseAsync(BuildConfig());

    private Task ResetAsync()
    {
        var cfg = new FilterConfig();
        HydrateFrom(cfg);              // clear every edit-field back to defaults
        return PersistAndRaiseAsync(cfg);
    }

    private async Task PersistAndRaiseAsync(FilterConfig cfg)
    {
        await JS.InvokeVoidAsync("localStorage.setItem", ConfigKey, cfg.ToJson());
        await OnFilterConfigChanged.InvokeAsync(cfg);
    }

    // Flush the current buffers / enum state into a single FilterConfig.
    private FilterConfig BuildConfig() => new()
    {
        Players = SplitTokens(_playerText),
        DecisionType = _decisionType,
        MatchScores = SplitTokens(_matchScoreText),
        ErrorMin = ParseDouble(_errorMinText),
        ErrorMax = ParseDouble(_errorMaxText),
        MoveNumberMin = ParseInt(_moveNumberMinText),
        MoveNumberMax = ParseInt(_moveNumberMaxText),
        ContactTypes = _contactTypes.ToList(),
        AnalysisLevels = _analysisLevels.ToList(),
        IncludeRollouts = _includeRollouts,
        IncludeBookRollouts = _includeBookRollouts,
        DiceRolls = _diceRolls.ToList(),
        PositionPattern = ParsePositionPattern(_positionPatternText),
    };

    // Inverse of BuildConfig: project a config onto the buffers / enum state.
    private void HydrateFrom(FilterConfig cfg)
    {
        _playerText = string.Join(", ", cfg.Players);
        _decisionType = cfg.DecisionType;
        _matchScoreText = string.Join(", ", cfg.MatchScores);
        _errorMinText = FormatNumber(cfg.ErrorMin);
        _errorMaxText = FormatNumber(cfg.ErrorMax);
        _moveNumberMinText = FormatNumber(cfg.MoveNumberMin);
        _moveNumberMaxText = FormatNumber(cfg.MoveNumberMax);
        _contactTypes = new HashSet<ContactType>(cfg.ContactTypes);
        _analysisLevels = new HashSet<AnalysisLevel>(cfg.AnalysisLevels);
        _includeRollouts = cfg.IncludeRollouts;
        _includeBookRollouts = cfg.IncludeBookRollouts;
        _diceRolls = new HashSet<DiceRoll>(cfg.DiceRolls);
        _positionPatternText = cfg.PositionPattern?.ToBracketList() ?? string.Empty;
    }

    // True when the position-pattern buffer is committable: a blank buffer is
    // "no pattern filter," and any non-blank buffer must parse as a bracket
    // list. Drives both the field's is-invalid styling and the Apply gate, so
    // half-typed input is flagged rather than silently dropped at Apply.
    private bool IsPositionPatternValid =>
        string.IsNullOrWhiteSpace(_positionPatternText)
        || BoardPattern.TryParse(_positionPatternText, out _);

    // Buffer → PositionPattern. A blank buffer is no filter (null); otherwise
    // the parsed pattern. TryParse can only fail here for invalid text, which
    // the Apply gate (IsPositionPatternValid) already prevents from reaching
    // BuildConfig — the null fallback is a defensive belt, not a silent drop.
    private static BoardPattern? ParsePositionPattern(string raw) =>
        string.IsNullOrWhiteSpace(raw)
            ? null
            : BoardPattern.TryParse(raw, out var pattern) ? pattern : null;

    private static List<string> SplitTokens(string raw) =>
        raw.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
           .Where(s => s.Length > 0).ToList();

    private static double? ParseDouble(string raw) =>
        double.TryParse(raw, System.Globalization.NumberStyles.Any,
                        System.Globalization.CultureInfo.InvariantCulture, out var v) ? v : null;

    private static int? ParseInt(string raw) =>
        int.TryParse(raw, System.Globalization.NumberStyles.Integer,
                     System.Globalization.CultureInfo.InvariantCulture, out var v) ? v : null;

    private static string FormatNumber<T>(T? value) where T : struct, IFormattable =>
        value?.ToString(null, System.Globalization.CultureInfo.InvariantCulture) ?? string.Empty;
}
